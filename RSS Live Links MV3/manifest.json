{
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "description": "__MSG_extDesc__",
   "version": "1.0",
   "default_locale": "en",
   "icons": {
      "128": "img/rssll_128x128.png",
      "16": "img/rssll_16x16.png",
      "32": "img/rssll_32x32.png",
      "48": "img/rssll_48x48.png"
   },
   "action": {
      "default_icon": "img/rssll_19x19.png",
      "default_popup": "popup.html",
      "default_title": "__MSG_extTitle__"
   },
   "background": {
      "service_worker": "scripts/service_worker.js"
   },
      "content_security_policy": {
         "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://* https://* http://192.168.1.1:3500 http://192.168.1.1:3200"
      },
   "options_page": "options.html",
   "permissions": [ "activeTab", "tabs", "contextMenus", "bookmarks", "storage", "offscreen", "scripting", "alarms" ],
   "host_permissions": [ "*://*/*" ],
   "update_url": "https://clients2.google.com/service/update2/crx"
}